<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Pad manifest.
  INTERNET is declared for the factory-local SkuRepository backend API (intranet only).
  No cloud QC inference path: no Qwen API, no DashScope, no remote inspection.
  No Location permissions.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Factory intranet API for SkuRepository (local network only, not cloud) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- READ_EXTERNAL_STORAGE / MANAGE_EXTERNAL_STORAGE for sdcard model sideload path -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-feature android:name="android.hardware.camera.any" android:required="true" />

    <application
        android:allowBackup="false"
        android:label="GiraffeQC-Pad"
        android:theme="@style/Theme.GiraffeQC">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Benchmark activity launched via adb for latency measurement -->
        <activity
            android:name=".benchmark.BenchmarkActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="com.giraffetechnology.qc.BENCHMARK" />
            </intent-filter>
        </activity>

    </application>
</manifest>
