# Copy this file to tests/config.env and fill in real values.
# NEVER commit tests/config.env — it is in .gitignore.

# DashScope / Qwen cloud API key (B1 real_api tests)
DASHSCOPE_API_KEY=

# Alias accepted by test harness
QWEN_TEST_API_KEY=

# Cloud endpoint
# Mainland China (default):
QWEN_CLOUD_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore alternative:
# QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Cloud oracle model (non-thinking instruct variant; probe actual available name)
QWEN_ORACLE_MODEL=qwen3-vl-8b-instruct

# Stronger reference model (optional)
# QWEN_ORACLE_MODEL=qwen3-vl-plus

# Physical Android device address for B2 @device tests
DEVICE_ADDR=192.168.5.62

# Max real API calls per session (cost gate)
MAX_REAL_CALLS=20
