# Xavier NX Administrator runner — production environment template.
# Copy to /etc/giraffe/xavier-admin-runner.env (mode 640, root:giraffe) and
# fill every <...> placeholder. See docs/JETSON_PRODUCTION_DEPLOYMENT_RUNBOOK.md.

APP_ENV=production
XAVIER_INFERENCE_MODE=real

# Stable provisioned device identity (recorded in every signed response).
JETSON_DEVICE_ID=<stable provisioned id>

# Bind to the administrator LAN address; TLS termination is required outside
# loopback (reverse proxy or stunnel in front of this port).
JETSON_BIND_HOST=<administrator LAN address>
JETSON_BIND_PORT=8600

# Pinned MNN bridge + exported VLM bundle. qwen3-vl-4b is the replaceable
# default model configuration, not a product identity.
XAVIER_MNN_BRIDGE_LIBRARY=/opt/giraffe/lib/libgiraffe_mnn_bridge.so
XAVIER_MNN_MODEL_DIR=/opt/giraffe/models/qwen3-vl-4b-mnn
XAVIER_MNN_MODEL_NAME=qwen3-vl-4b

# Provisioned bearer -> {display_name, ed25519_public_key, ...} map (JSON).
XAVIER_ADMIN_CREDENTIALS_JSON=<provisioned credentials JSON>

# Hardware validation gate: stays not_run until a reviewed immutable evidence
# record exists (jetson_runner/HARDWARE_VALIDATION.md). CI can never set this.
XAVIER_HARDWARE_VALIDATION_STATUS=not_run
#XAVIER_HARDWARE_VALIDATION_EVIDENCE_REF=<immutable evidence reference>
