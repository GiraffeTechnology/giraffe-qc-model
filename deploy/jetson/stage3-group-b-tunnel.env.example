# Stage 3 Group B remote-VLM tunnel — environment template.
# Copy to /etc/giraffe/stage3-group-b-tunnel.env (mode 640, root:giraffe) and
# fill every <...> placeholder. See docs/STAGE3_GROUP_B_REMOTE_ADAPTER.md.
#
# Do not commit a filled-in copy of this file, and do not paste real values
# from it into a PR description, README, or any other repo-tracked file —
# host identity and network topology are internal deployment information.

# Dedicated key, restricted on the remote host's authorized_keys entry to
# command="/bin/false",no-agent-forwarding,no-X11-forwarding,no-pty,
# permitopen="127.0.0.1:<remote-service-port>" — never a general-purpose key.
TUNNEL_SSH_KEY_PATH=/etc/giraffe/keys/stage3-group-b-tunnel

TUNNEL_SSH_USER=<restricted tunnel user on the remote host>
TUNNEL_REMOTE_HOST=<remote host address>

# Must match the remote chat-completions service's own loopback port.
TUNNEL_REMOTE_PORT=<remote service port>

# Local Jetson loopback port that RemoteChatVlmInspectionProvider's
# VLM_BASE_URL (http://127.0.0.1:<this port>) will target.
TUNNEL_LOCAL_PORT=<local forwarded port>
