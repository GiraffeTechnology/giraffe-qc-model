# SANDBOX TEST CONFIGURATION ONLY — copy to repository-root sandbox.env.
# sandbox.env is gitignored and must never be pasted into a PR, report, or log.
SANDBOX_QC_SERVER=https://replace-with-out-of-band-sandbox-host
SANDBOX_QC_MODEL=replace-with-sandbox-model
SANDBOX_QC_API_STYLE=openai_chat
SANDBOX_QC_INFERENCE_PATH=/v1/chat/completions
SANDBOX_QC_API_KEY=
SANDBOX_QC_TIMEOUT_SECONDS=60
SANDBOX_QC_MAX_IMAGE_BYTES=5242880
SANDBOX_QC_MAX_OUTPUT_CHARS=100000
SANDBOX_QC_MAX_TOKENS=256

# These values exist only to generate the mandatory model-delta report note.
SANDBOX_PRODUCTION_CLOUD_MODEL=replace-with-production-cloud-default
SANDBOX_PRODUCTION_ADMIN_MODEL=replace-with-production-admin-default
