# ── Database ──────────────────────────────────────────────────────────────────────────────
# Default: SQLite for local dev. Use postgresql+psycopg2://... for production.
QC_DB_URL=sqlite:///./giraffe_qc.db

# ── Provider-neutral multimodal layer ───────────────────────────────────────────
MULTIMODAL_PROVIDER=qwen
MULTIMODAL_ENABLE_REAL_CALLS=false
MULTIMODAL_TIMEOUT_SECONDS=60
MULTIMODAL_MAX_RETRIES=2
# qwen | openai | anthropic | local_mnn | mock | cv
MULTIMODAL_DEFAULT_MODEL=

# ── Qwen / DashScope adapter ───────────────────────────────────────────────
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_MULTIMODAL_MODEL=
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# ── Other provider placeholders ──────────────────────────────────────────────
OPENAI_MULTIMODAL_MODEL=
OPENAI_API_KEY=
ANTHROPIC_MULTIMODAL_MODEL=
ANTHROPIC_API_KEY=

# ── QC routing policy ────────────────────────────────────────────────────────
QC_ROUTING_MODE=local_first
QC_ALLOW_CLOUD_FALLBACK=false
QC_REQUIRE_USER_CONSENT_FOR_CLOUD=true
QC_ALLOW_SEND_IMAGES_TO_CLOUD=false
QC_CLOUD_CAN_OVERRIDE_LOCAL_FAIL=false
QC_MIN_PASS_CONFIDENCE=0.82

# ── Legacy LLM: Qwen / DashScope (kept for backward compatibility) ─────────────────
# DASHSCOPE_API_KEY is shared with the provider-neutral layer above.
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-turbo

# Set to "true" to enable real Qwen API calls (legacy; prefer MULTIMODAL_ENABLE_REAL_CALLS)
LLM_ENABLE_REAL_CALLS=false

# ── Video pipeline ───────────────────────────────────────────────────────────────
TIER1_DIFF_THRESHOLD=5
LOCAL_PREFILTER_THRESHOLD=0.25
VIDEO_SAMPLE_FPS=2

# ── Storage ───────────────────────────────────────────────────────────────────────
SAMPLE_STORE_DIR=data/samples
CAPTURE_DIR=data/captures
