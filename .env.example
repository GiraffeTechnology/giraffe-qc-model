# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite for local dev. Use postgresql+psycopg2://... for production.
QC_DB_URL=sqlite:///./giraffe_qc.db

# ── LLM: Qwen / DashScope (China node) ───────────────────────────────────────
# Required for real image comparison calls.
DASHSCOPE_API_KEY=<PLACEHOLDER>
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-turbo

# Set to "true" to enable real Qwen API calls (default: false → mock mode)
LLM_ENABLE_REAL_CALLS=false

# ── Video pipeline ─────────────────────────────────────────────────────────────
# Tier-1: skip frame if mean-abs-diff < this threshold (0-255)
TIER1_DIFF_THRESHOLD=5
# Tier-2: ORB match score required to send frame to LLM (0.0-1.0)
LOCAL_PREFILTER_THRESHOLD=0.25
# Sample frames per second from input video (0 = every frame)
VIDEO_SAMPLE_FPS=2

# ── Storage ───────────────────────────────────────────────────────────────────
SAMPLE_STORE_DIR=data/samples
CAPTURE_DIR=data/captures

# ── Security / Auth (P0) ──────────────────────────────────────────────────────
# Signs admin cookie sessions. Startup FAILS outside APP_ENV=test if this is
# unset or left at the dev default. Use a long random value in production.
SESSION_SECRET=<CHANGE-ME-strong-random-value>
# Signs API bearer tokens (mint via src.api.auth.mint_token). Falls back to
# SESSION_SECRET when unset.
API_TOKEN_SECRET=<CHANGE-ME-strong-random-value>
# Optional static API keys: JSON map of key -> {"tenant_id": "...", "admin": bool}
# QC_API_KEYS={"key-abc":{"tenant_id":"acme","admin":false}}
# Demo operators (password == username) are NEVER auto-seeded in production
# unless this is explicitly set to true.
QC_SEED_DEMO_OPERATORS=false
# Max upload size in bytes for image uploads (default 10 MB).
MAX_UPLOAD_BYTES=10485760
