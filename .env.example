# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite for local dev. External deployments select a configured
# SQLAlchemy driver, for example mysql+pymysql://... for MySQL.
QC_DB_URL=sqlite:///./giraffe_qc.db

# ── Admin Studio live assistants (provider-neutral) ──────────────────────────
# Deployment-selected defaults. The product does not require these providers
# or models; any compatible text / vision service can replace them.
STUDIO_TEXT_PROVIDER=ollama_compatible
STUDIO_TEXT_BASE_URL=
STUDIO_TEXT_MODEL=
STUDIO_VISION_PROVIDER=openai_compatible
STUDIO_VISION_BASE_URL=
STUDIO_VISION_MODEL=
STUDIO_AI_TIMEOUT_SECONDS=90

# ── Legacy optional DashScope adapter ────────────────────────────────────────
# Only required when this optional cloud adapter is explicitly selected.
DASHSCOPE_API_KEY=<PLACEHOLDER>
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-turbo

# Set to "true" to enable real Qwen API calls (default: false → mock mode)
LLM_ENABLE_REAL_CALLS=false

# ── Video pipeline ─────────────────────────────────────────────────────────────
# Tier-1: skip frame if mean-abs-diff < this threshold (0-255)
TIER1_DIFF_THRESHOLD=5
# Tier-2: ORB match score required to send frame to LLM (0.0-1.0)
LOCAL_PREFILTER_THRESHOLD=0.25
# Sample frames per second from input video (0 = every frame)
VIDEO_SAMPLE_FPS=2

# ── Storage ───────────────────────────────────────────────────────────────────
SAMPLE_STORE_DIR=data/samples
CAPTURE_DIR=data/captures

# ── Edge CV (optional hot-pluggable co-processor) ─────────────────────────────
# Optional feature. Set EDGE_CV_ENABLED=false to disable entirely; the rest of
# the system then behaves exactly as before. CI runs entirely in mock mode and
# never requires real Jetson hardware.
EDGE_CV_ENABLED=true
EDGE_CV_HOTPLUG_ENABLED=true
EDGE_CV_MOCK_ENABLED=true
EDGE_CV_CPU_FALLBACK=true

EDGE_CV_HEARTBEAT_INTERVAL_SECONDS=10
EDGE_CV_HEARTBEAT_TTL_SECONDS=35
EDGE_CV_JOB_LEASE_SECONDS=60
EDGE_CV_JOB_POLL_INTERVAL_SECONDS=3
EDGE_CV_MAX_RETRIES=2

EDGE_CV_DEFAULT_DEVICE_TYPE=jetson_nano_2gb
EDGE_CV_MODEL_DIR=/opt/giraffe/models
# Text assistant JSON output budget (bounded to 768..4096; 1024 fits multi-point drafts).
STUDIO_TEXT_NUM_PREDICT=1024

EDGE_CV_OUTPUT_DIR=/opt/giraffe/cv_outputs

# Device-registration bootstrap secret. When set, every device must present it
# as the X-Edge-CV-Bootstrap-Token header on /api/edge-cv/devices/register.
# In production, registration is REJECTED if this is unset, unless you opt into
# insecure mode with EDGE_CV_ALLOW_INSECURE_REGISTRATION=true. Never commit a
# real secret. (EDGE_CV_BOOTSTRAP_TOKEN is accepted as an alias.)
EDGE_CV_REGISTRATION_SECRET=<PLACEHOLDER>
EDGE_CV_ALLOW_INSECURE_REGISTRATION=false
# Live-capture dedup window (seconds) — suppress re-capturing the same object.
EDGE_CV_RECAPTURE_COOLDOWN_SECONDS=5

# ── Jetson Xavier NX inference runner (optional; runs as a separate service) ──
# These configure the headless mock runner in jetson_runner/. The Server side
# needs no extra config — the Pad relays pairing/health on sync. Mock mode needs
# no hardware. Real deployments set JETSON_MOCK_MODE=false on the device.
JETSON_MOCK_MODE=true
JETSON_PAIRING_WINDOW_SECONDS=120
JETSON_BIND_HOST=0.0.0.0
JETSON_BIND_PORT=8600
JETSON_STATUS_LED=false
