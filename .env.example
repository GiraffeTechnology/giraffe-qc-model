# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite for local dev. Use postgresql+psycopg2://... for production.
QC_DB_URL=sqlite:///./giraffe_qc.db

# ── LLM: Qwen / DashScope (China node) ───────────────────────────────────────
# Required for real image comparison calls.
DASHSCOPE_API_KEY=<PLACEHOLDER>
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-turbo

# Set to "true" to enable real Qwen API calls (default: false → mock mode)
LLM_ENABLE_REAL_CALLS=false

# ── Video pipeline ─────────────────────────────────────────────────────────────
# Tier-1: skip frame if mean-abs-diff < this threshold (0-255)
TIER1_DIFF_THRESHOLD=5
# Tier-2: ORB match score required to send frame to LLM (0.0-1.0)
LOCAL_PREFILTER_THRESHOLD=0.25
# Sample frames per second from input video (0 = every frame)
VIDEO_SAMPLE_FPS=2

# ── Storage ───────────────────────────────────────────────────────────────────
SAMPLE_STORE_DIR=data/samples
CAPTURE_DIR=data/captures
